{:paths ["src" "test"]
 :deps {org.babashka/cli {:mvn/version "0.8.62"}
        org.babashka/json {:mvn/version "0.1.6"}}
 :tasks
 {:requires ([babashka.fs :as fs])

  test {:doc  "Run Section sims (tests)"
        :task ((requiring-resolve 'section.sim-test/-main))}

  run {:doc  "Run Birkoff once (poll → dispatch)"
       :override-builtin true
       :task (load-file "birkoff.bb")}

  status {:doc  "Show Section status — capabilities, locks, memory"
          :task ((requiring-resolve 'section.oversight/status-report))}

  walter {:doc  "Check all capabilities"
          :task ((requiring-resolve 'section.walter/report))}

  housekeeping {:doc  "Clean stale locks and prune branches"
                :task ((requiring-resolve 'section.oversight/housekeeping!))}

  repo {:doc  "Manage monitored repos (bb repo help for subcommands)"
        :task ((requiring-resolve 'section.registry/cli) *command-line-args*)}

  mission {:doc  "Manage what Birkoff works on (bb mission help)"
           :task ((requiring-resolve 'section.mission/cli) *command-line-args*)}

  perch {:doc  "Start The Perch (web dashboard) in foreground"
         :task ((requiring-resolve 'section.perch/-main) (first *command-line-args*))}

  install {:doc  "Install both launchd plists (Birkoff + Perch)"
           :task (let [home   (System/getProperty "user.home")
                       la-dir (str home "/Library/LaunchAgents")
                       bk-dst (str la-dir "/com.section.birkoff.plist")
                       pc-dst (str la-dir "/com.section.perch.plist")]
                   (shell "cp" "com.section.birkoff.plist" bk-dst)
                   (shell "cp" "com.section.perch.plist"   pc-dst)
                   (shell "launchctl" "load" bk-dst)
                   (shell "launchctl" "load" pc-dst)
                   (println "Section installed. Birkoff + Perch online."))}

  uninstall {:doc  "Remove both launchd plists"
             :task (let [home   (System/getProperty "user.home")
                         la-dir (str home "/Library/LaunchAgents")
                         bk-dst (str la-dir "/com.section.birkoff.plist")
                         pc-dst (str la-dir "/com.section.perch.plist")]
                     (shell {:continue true} "launchctl" "unload" bk-dst)
                     (shell {:continue true} "launchctl" "unload" pc-dst)
                     (shell {:continue true} "rm" bk-dst)
                     (shell {:continue true} "rm" pc-dst)
                     (println "Section uninstalled."))}}}
