{:paths ["src" "test"]
 :deps {org.babashka/cli {:mvn/version "0.8.62"}
        org.babashka/json {:mvn/version "0.1.6"}}
 :tasks
 {:requires ([babashka.fs :as fs])

  test {:doc  "Run Section sims (tests)"
        :task ((requiring-resolve 'section.sim-test/-main))}

  run {:doc  "Run Birkoff once (poll → dispatch)"
       :override-builtin true
       :task (load-file "birkoff.bb")}

  status {:doc  "Show Section status — capabilities, locks, memory"
          :task ((requiring-resolve 'section.oversight/status-report))}

  walter {:doc  "Check all capabilities"
          :task ((requiring-resolve 'section.walter/report))}

  housekeeping {:doc  "Clean stale locks and prune branches"
                :task ((requiring-resolve 'section.oversight/housekeeping!))}

  install {:doc  "Install the launchd plist"
           :task (let [plist (str (System/getProperty "user.home") "/Library/LaunchAgents/com.section.birkoff.plist")]
                   (shell "cp" "com.section.birkoff.plist" plist)
                   (shell "launchctl" "load" plist))}

  uninstall {:doc  "Remove the launchd plist"
             :task (let [plist (str (System/getProperty "user.home") "/Library/LaunchAgents/com.section.birkoff.plist")]
                     (shell "launchctl" "unload" plist)
                     (shell "rm" plist))}}}
